<?xml version="1.0" ?>
<!--
  SLAM test world for the Seeker hexapod robot.
  Contains walls and obstacles to generate interesting LiDAR scans
  and camera views for SLAM algorithm development.
-->
<sdf version="1.9">
  <world name="slam_test_world">

    <!-- Physics -->
    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <ode>
        <solver>
          <type>quick</type>
          <iters>150</iters>
          <sor>1.3</sor>
        </solver>
        <constraints>
          <cfm>1e-5</cfm>
          <erp>0.2</erp>
          <contact_surface_layer>0.001</contact_surface_layer>
        </constraints>
      </ode>
    </physics>

    <!-- Required system plugins -->
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>

    <!-- Lighting -->
    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <!-- Ground plane -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry><plane><normal>0 0 1</normal><size>20 20</size></plane></geometry>
        </collision>
        <visual name="visual">
          <geometry><plane><normal>0 0 1</normal><size>20 20</size></plane></geometry>
          <material>
            <ambient>0.6 0.6 0.6 1</ambient>
            <diffuse>0.7 0.7 0.7 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ============================================================ -->
    <!-- Room walls (5m x 5m enclosure)                                -->
    <!-- ============================================================ -->
    <!-- North wall -->
    <model name="wall_north">
      <static>true</static>
      <pose>0 2.5 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>5.0 0.1 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>5.0 0.1 1.0</size></box></geometry>
          <material><ambient>0.8 0.8 0.75 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- South wall -->
    <model name="wall_south">
      <static>true</static>
      <pose>0 -2.5 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>5.0 0.1 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>5.0 0.1 1.0</size></box></geometry>
          <material><ambient>0.8 0.8 0.75 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- East wall -->
    <model name="wall_east">
      <static>true</static>
      <pose>2.5 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.1 5.0 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.1 5.0 1.0</size></box></geometry>
          <material><ambient>0.8 0.8 0.75 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- West wall -->
    <model name="wall_west">
      <static>true</static>
      <pose>-2.5 0 0.5 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.1 5.0 1.0</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.1 5.0 1.0</size></box></geometry>
          <material><ambient>0.8 0.8 0.75 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- ============================================================ -->
    <!-- Interior obstacles for SLAM feature detection                  -->
    <!-- ============================================================ -->
    <!-- Box obstacle 1 -->
    <model name="box_obstacle_1">
      <static>true</static>
      <pose>1.0 1.0 0.25 0 0 0.3</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.5 0.5 0.5</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.5 0.5 0.5</size></box></geometry>
          <material><ambient>0.8 0.3 0.2 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- Box obstacle 2 -->
    <model name="box_obstacle_2">
      <static>true</static>
      <pose>-1.2 0.8 0.3 0 0 -0.5</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.4 0.6 0.6</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.4 0.6 0.6</size></box></geometry>
          <material><ambient>0.2 0.6 0.3 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- Cylinder obstacle -->
    <model name="cylinder_obstacle">
      <static>true</static>
      <pose>0.5 -1.2 0.4 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><cylinder><radius>0.2</radius><length>0.8</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.2</radius><length>0.8</length></cylinder></geometry>
          <material><ambient>0.3 0.3 0.8 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- L-shaped wall (two segments) -->
    <model name="l_wall_a">
      <static>true</static>
      <pose>-0.8 -1.0 0.4 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>1.0 0.08 0.8</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>1.0 0.08 0.8</size></box></geometry>
          <material><ambient>0.7 0.6 0.4 1</ambient></material>
        </visual>
      </link>
    </model>

    <model name="l_wall_b">
      <static>true</static>
      <pose>-1.3 -1.5 0.4 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><box><size>0.08 1.0 0.8</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>0.08 1.0 0.8</size></box></geometry>
          <material><ambient>0.7 0.6 0.4 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- Small pillar -->
    <model name="pillar">
      <static>true</static>
      <pose>1.5 -0.5 0.35 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><cylinder><radius>0.1</radius><length>0.7</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.1</radius><length>0.7</length></cylinder></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient></material>
        </visual>
      </link>
    </model>

    <!-- ============================================================ -->
    <!-- Target ball for ball-search task                              -->
    <!-- Bright red sphere at (1.8, -1.8) — corner of the room.       -->
    <!-- Detectable via camera HSV thresholding (red hue).            -->
    <!-- ============================================================ -->
    <model name="target_ball">
      <static>true</static>
      <pose>1.8 -1.8 0.1 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry><sphere><radius>0.1</radius></sphere></geometry>
        </collision>
        <visual name="visual">
          <geometry><sphere><radius>0.1</radius></sphere></geometry>
          <material>
            <ambient>1.0 0.05 0.05 1</ambient>
            <diffuse>1.0 0.05 0.05 1</diffuse>
            <specular>0.8 0.0 0.0 1</specular>
          </material>
        </visual>
      </link>
    </model>

  </world>
</sdf>
