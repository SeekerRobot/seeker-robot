Panels:
  - Class: rviz_common/Displays
    Help Height: 280
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Plan1
        - /Local Plan1
        - /LaserScan1
      Splitter Ratio: 0.5
    Tree Height: 163
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
