# ----------------------------------------------------------------------
# Project Environment Configuration
# ----------------------------------------------------------------------

# ======================================================================
# 0. PROJECT NAME
# ======================================================================
# Used as the Docker Compose project name (container prefix).
# Set a unique value per worktree to avoid container/volume collisions.
#
COMPOSE_PROJECT_NAME=seeker-robot

# ======================================================================
# 1. BUILD STRATEGY (Multi-Stage Docker)
# ======================================================================
# Controls which stage of the Dockerfile is built.
#
# The vision stack (tensorflow[and-cuda] + ultralytics + deepface) adds
# ~5 GB to the image, so it's opt-in. Pick `*-vision` only if you plan
# to run seeker_vision nodes (YOLO / emotion detection).
#
# Options:
#   dev         -> Gazebo, RViz, Nav2, SLAM Toolbox. No vision.      (PC/Laptop, MCU-only work)
#   dev-vision  -> dev + vision stack.                               (PC/Laptop, running seeker_vision)
#   prod        -> Minimal runtime, no simulators, no vision.        (Robot deployment, MCU-only)
#   prod-vision -> Minimal runtime + vision stack.                   (Robot deployment, on-robot inference)
#
BUILD_TARGET=dev

# ======================================================================
# 2. GRAPHICS & NETWORK CONFIGURATION
# ======================================================================
# Uncomment the block below that matches your operating system.

# 🐧 LINUX NATIVE CONFIGURATION:
# Use this if you are running Ubuntu/Debian natively.
DISPLAY_CONFIG=${DISPLAY}
NETWORK_MODE_CONFIG=host

# 🍎 WINDOWS / 🍏 MACOS (DOCKER DESKTOP):
# Use this if you are using Docker Desktop.
# Requires an XServer (VcXsrv/XQuartz) installed on host.
# DISPLAY_CONFIG=host.docker.internal:0
# NETWORK_MODE_CONFIG=bridge

# ======================================================================
# 3. FISH AUDIO TTS
# ======================================================================
# API credentials for the seeker_tts ROS 2 node.
# Get your key at https://fish.audio
#
FISH_API_KEY=
FISH_REFERENCE_ID=
